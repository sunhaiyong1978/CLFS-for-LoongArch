source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=glibc_localedata
export PACKAGE_VERSION=2.43
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/glibc_localedata/2.43/
rm -rf ${BUILD_DIRECTORY}/glibc-2.43
tar xvf ${DOWNLOADDIR}/glibc-2.43.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/glibc-2.43
	patch -Np1 -i ${SYSDIR}/files/core/glibc_localedata/2.43/patches/0001-glibc-add-C.UTF-8-to-localedata.patch 
	 
        mkdir -p build-locale
        pushd build-locale
		export CFLAGS=""
		export LDFLAGS=""
                ../configure --prefix=/usr --libdir=/usr/lib${LIB_SUFF} --libexecdir=/usr/lib${LIB_SUFF}/glibc \
                         --enable-stack-protector=strong --enable-add-ons \
                         --disable-werror libc_cv_slibdir=/usr/lib${LIB_SUFF}
                make -j${JOBS}
                make -j${JOBS} DESTDIR=${SYSROOT_DIR} localedata/install-locales
popd 
rm -rf ${BUILD_DIRECTORY}/glibc-2.43
