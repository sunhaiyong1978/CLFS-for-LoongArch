source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=glib_pre
export PACKAGE_VERSION=2.89.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/glib_pre/2.89.0/
rm -rf ${BUILD_DIRECTORY}/glib-2.89.0
tar xvf ${DOWNLOADDIR}/glib-2.89.0.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/glib-2.89.0
        
        mkdir cross-build
        pushd cross-build
                meson ${MESON_CONFIG} --default-library=both -Dtests=false -Dman=true -Dselinux=disabled -Dintrospection=disabled -Dman-pages=false \
                      ..
                eval ${NINJA_AND_INSTALL}
        popd
        rm -f ${SYSROOT_DIR}/usr/lib64/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/glib-2.89.0
