source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=texinfo
export PACKAGE_VERSION=7.3
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/texinfo/7.3/
rm -rf ${BUILD_DIRECTORY}/texinfo-7.3
tar xvf ${DOWNLOADDIR}/texinfo-7.3.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/texinfo-7.3
	sed -e 's/__attribute_nonnull__/__nonnull/' \
	    -i gnulib/lib/malloc/dynarray-skeleton.c
        for config_i in $(find -name "config.sub")
        do
                cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
        done
	./configure --prefix=/usr --build=${CROSS_HOST} --host=${CROSS_TARGET} texinfo_cv_sys_iconv_converts_euc_cn=y
        make -j${JOBS} -C tools/gnulib/lib
        make -j${JOBS} -C tools/info makedoc
	eval ${MAKE_AND_INSTALL}
	make DESTDIR=${SYSROOT_DIR} TEXMF=/usr/share/texmf install-tex
popd 
rm -rf ${BUILD_DIRECTORY}/texinfo-7.3
