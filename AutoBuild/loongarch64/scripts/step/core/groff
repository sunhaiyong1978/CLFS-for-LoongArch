source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=groff
export PACKAGE_VERSION=1.24.1
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/groff/1.24.1/
rm -rf ${BUILD_DIRECTORY}/groff-1.24.1
tar xvf ${DOWNLOADDIR}/groff-1.24.1.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/groff-1.24.1
        for config_i in $(find -name "config.sub")
        do
                cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
        done
        sed -i "/^GROFF_BIN_PATH/s@\$builddir@${CROSSTOOLS_DIR}/bin@g" test-groff.in
        sed -i "s@\$builddir/groff@${CROSSTOOLS_DIR}/bin/groff@g" test-groff.in
        sed -i "s@GROFF_COMMAND=test-groff@GROFF_COMMAND=${PWD}/test-groff@g" Makefile.in
        PAGE=A4 ./configure --prefix=/usr --build=${CROSS_HOST} --host=${CROSS_TARGET}
        make -j${JOBS} GROFFBIN=${CROSSTOOLS_DIR}/bin/groff GROFF_BIN_PATH=${CROSSTOOLS_DIR}/bin/
        make DESTDIR=${SYSROOT_DIR} install
popd 
rm -rf ${BUILD_DIRECTORY}/groff-1.24.1
