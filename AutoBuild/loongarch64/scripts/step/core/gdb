source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=gdb
export PACKAGE_VERSION=17.2
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/gdb/17.2/
rm -rf ${BUILD_DIRECTORY}/gdb-17.2
tar xvf ${DOWNLOADDIR}/gdb-17.2.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/gdb-17.2
        
        for config_i in $(find -name "config.sub")
        do
                cp -a -f $(automake --print-libdir)/config.* $(dirname ${config_i})/
        done
        if [ ! -f configure ]; then
                autoreconf -ifv
        fi
	sed -i "s@ ac_cv_guild_program_name=\(.*\)@ ac_cv_guild_program_name=${CROSSTOOLS_DIR}/bin/guild@g" gdb/configure
                ./configure ${COMMON_CONFIG} --enable-shared --disable-werror --with-system-zlib --enable-64-bit-bfd --with-system-readline --with-libgmp-prefix=${SYSROOT_DIR} --with-libexpat-prefix=${SYSROOT_DIR}
                eval ${MAKE_AND_INSTALL}
        rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/gdb-17.2
