source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=libgcrypt
export PACKAGE_VERSION=1.12.2
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/libgcrypt/1.12.2/
rm -rf ${BUILD_DIRECTORY}/libgcrypt-1.12.2
tar xvf ${DOWNLOADDIR}/libgcrypt-1.12.2.tar.bz2 -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/libgcrypt-1.12.2
    for config_i in $(find -name "config.sub")
    do
            cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
    done
    ./configure ${COMMON_CONFIG} --disable-amd64-as-feature-detection SYSROOT=${SYSROOT_DIR} GPGRT_CONFIG=${CROSSTOOLS_DIR}/bin/gpgrt-config
    eval ${MAKE_AND_INSTALL}
    cp -av ${SYSROOT_DIR}/bin/libgcrypt-config ${CROSSTOOLS_DIR}/bin/
popd 
rm -rf ${BUILD_DIRECTORY}/libgcrypt-1.12.2
