source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=freetype
export PACKAGE_VERSION=2.14.3
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/freetype/2.14.3/
rm -rf ${BUILD_DIRECTORY}/freetype-2.14.3
tar xvf ${DOWNLOADDIR}/freetype-2.14.3.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/freetype-2.14.3
    sed -ri "s:.*(AUX_MODULES.*valid):\1:" modules.cfg
    sed -r "s:.*(#.*SUBPIXEL_RENDERING) .*:\1:" \
           -i include/freetype/config/ftoption.h
    ./configure ${COMMON_CONFIG} \
                --enable-freetype-config
    eval ${MAKE_AND_INSTALL}

    sed -i -e "s@${CROSSTOOLS_DIR}/bin@/usr/bin@g" \
           -e "s@${CROSS_TARGET}-@@g" \
           ${SYSROOT_DIR}/usr/bin/freetype-config
popd 
rm -rf ${BUILD_DIRECTORY}/freetype-2.14.3
