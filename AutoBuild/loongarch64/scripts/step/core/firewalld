source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=firewalld
export PACKAGE_VERSION=2.4.1
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/firewalld/2.4.1/
rm -rf ${BUILD_DIRECTORY}/firewalld-2.4.1
tar xvf ${DOWNLOADDIR}/firewalld-2.4.1.tar.bz2 -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/firewalld-2.4.1
	
	for config_i in $(find -name "config.sub")
	do
		chmod 0644 $(dirname ${config_i})/config.{sub,guess}
		cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
	done
	if [ ! -f configure ]; then
		autoreconf -ifv
	fi
	 ./configure ${COMMON_CONFIG} PYTHON=${CROSSTOOLS_DIR}/bin/${CROSS_TARGET}-python3 --disable-docs --enable-malloc0returnsnull
	CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" make -j${JOBS}
	run_step_package_check check
        make DESTDIR=${SYSROOT_DIR} install
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/firewalld-2.4.1
