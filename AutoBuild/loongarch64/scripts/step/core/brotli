source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=brotli
export PACKAGE_VERSION=1.2.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/brotli/1.2.0/
rm -rf ${BUILD_DIRECTORY}/brotli-1.2.0
tar xvf ${DOWNLOADDIR}/brotli-1.2.0.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/brotli-1.2.0
        patch -Np1 -i ${SYSDIR}/files/core/brotli/1.2.0/patches/0001-fix-BROTLI_MODEL-from-small-to-normal-for-loongarch.patch 
	 
	mkdir cross-build
	pushd cross-build
        	CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++"  \
		cmake -G "Unix Makefiles" -DCMAKE_BUILD_TYPE=Release -DCMAKE_TOOLCHAIN_FILE=${COMMON_DIR}/cmake-cross.cmake \
		      -DCMAKE_INSTALL_LIBDIR=/usr/lib${LIB_SUFF} \
       		      -DCMAKE_INSTALL_PREFIX=/usr  -Wno-dev ..
		eval ${MAKE_AND_INSTALL}
	popd
        rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/brotli-1.2.0
