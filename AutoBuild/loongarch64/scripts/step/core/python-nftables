source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=python-nftables
export PACKAGE_VERSION=1.1.6
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/python-nftables/1.1.6/
rm -rf ${BUILD_DIRECTORY}/nftables-1.1.6
tar xvf ${DOWNLOADDIR}/nftables-1.1.6.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/nftables-1.1.6
	pushd py
		CC=${CROSS_TARGET}-gcc CXX=${CROSS_TARGET}-g++ _PYTHON_SYSCONFIGDATA_NAME=_sysconfigdata__linux_${CROSS_TARGET} ${CROSSTOOLS_DIR}/bin/pip3 wheel -w dist --no-build-isolation --no-deps ${PWD}
		CC=${CROSS_TARGET}-gcc CXX=${CROSS_TARGET}-g++ _PYTHON_SYSCONFIGDATA_NAME=_sysconfigdata__linux_${CROSS_TARGET} ${CROSSTOOLS_DIR}/bin/pip3 install --no-index --find-links dist --no-cache-dir --no-deps --ignore-installed --no-user nftables --root=${SYSROOT_DIR} --prefix=/usr
	popd
popd 
rm -rf ${BUILD_DIRECTORY}/nftables-1.1.6
