source env/core/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=core
export STEP_PACKAGENAME=pygobject
export PACKAGE_VERSION=3.56.3
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/core/pygobject/3.56.3/
rm -rf ${BUILD_DIRECTORY}/pygobject-3.56.3
tar xvf ${DOWNLOADDIR}/pygobject-3.56.3.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/pygobject-3.56.3
    mkdir cross-build
    pushd cross-build
        meson ${MESON_CONFIG} -Dtests=false ..
        CC="${CROSS_TARGET}-gcc" ninja
        DESTDIR=${SYSROOT_DIR} ninja install
    popd
popd 
rm -rf ${BUILD_DIRECTORY}/pygobject-3.56.3
