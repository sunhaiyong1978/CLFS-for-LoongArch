source env/cross-tools/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=cross-tools
export STEP_PACKAGENAME=grub
export PACKAGE_VERSION=2.14
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/cross-tools/grub/2.14/
rm -rf ${BUILD_DIRECTORY}/grub-2.14
tar xvf ${DOWNLOADDIR}/grub-2.14.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/grub-2.14
        
	touch grub-core/extra_deps.lst
        PYTHON=${CROSSTOOLS_DIR}/bin/python3 ./configure --prefix=${CROSSTOOLS_DIR} --build=${CROSS_HOST} \
                --host=${CROSS_HOST} --target=${CROSS_TARGET} \
		--program-transform-name=s,grub,${CROSS_TARGET}-grub, --with-platform=efi --with-utils=host --disable-werror
        eval ${MAKE_AND_INSTALL}
popd 
rm -rf ${BUILD_DIRECTORY}/grub-2.14
