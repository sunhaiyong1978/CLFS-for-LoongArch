source env/cross-tools/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=cross-tools
export STEP_PACKAGENAME=setuptools
export PACKAGE_VERSION=82.0.1
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/cross-tools/setuptools/82.0.1/
rm -rf ${BUILD_DIRECTORY}/setuptools-82.0.1
tar xvf ${DOWNLOADDIR}/setuptools-82.0.1.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/setuptools-82.0.1
	
	${CROSSTOOLS_DIR}/bin/python3 -m pip wheel -w dist --no-build-isolation --no-deps ${PWD}
