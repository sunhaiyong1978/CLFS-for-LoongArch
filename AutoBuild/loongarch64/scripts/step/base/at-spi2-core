source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=at-spi2-core
export PACKAGE_VERSION=2.60.4
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/at-spi2-core/2.60.4/
rm -rf ${BUILD_DIRECTORY}/at-spi2-core-2.60.4
tar xvf ${DOWNLOADDIR}/at-spi2-core-2.60.4.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/at-spi2-core-2.60.4
	
	mkdir cross-build
	pushd cross-build
		meson ${MESON_CONFIG} -Ddefault_bus=dbus-broker -Ddbus_broker=/usr/bin/dbus-broker -Ddbus_daemon=/usr/bin/dbus-daemon -Dintrospection=enabled \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/at-spi2-core-2.60.4
