source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=gcr
export PACKAGE_VERSION=4.4.0.1
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/gcr/4.4.0.1/
rm -rf ${BUILD_DIRECTORY}/gcr-4.4.0.1
tar xvf ${DOWNLOADDIR}/gcr-4.4.0.1.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/gcr-4.4.0.1
	patch -Np1 -i ${SYSDIR}/files/base/gcr/4.4.0.1/patches/0001-gcr-fix-systemd-dir-for-cross-build.patch 
	 
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG} -Dgtk_doc=false \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}*.la
popd 
rm -rf ${BUILD_DIRECTORY}/gcr-4.4.0.1
