source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=glu
export PACKAGE_VERSION=9.0.3
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/glu/9.0.3/
rm -rf ${BUILD_DIRECTORY}/glu-9.0.3
tar xvf ${DOWNLOADDIR}/glu-9.0.3.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/glu-9.0.3
	
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG} -Dgl_provider=gl \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}*.la
popd 
rm -rf ${BUILD_DIRECTORY}/glu-9.0.3
