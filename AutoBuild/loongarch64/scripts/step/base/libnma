source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=libnma
export PACKAGE_VERSION=1.10.6
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/libnma/1.10.6/
rm -rf ${BUILD_DIRECTORY}/libnma-1.10.6
tar xvf ${DOWNLOADDIR}/libnma-1.10.6.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/libnma-1.10.6
	
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG} -Dvapi=false -Dgtk_doc=false -Dlibnma_gtk4=true -Dmobile_broadband_provider_info=false -Dintrospection=true \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/libnma-1.10.6
