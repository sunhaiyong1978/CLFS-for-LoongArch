source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=libarchive
export PACKAGE_VERSION=3.8.7
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/libarchive/3.8.7/
rm -rf ${BUILD_DIRECTORY}/libarchive-3.8.7
tar xvf ${DOWNLOADDIR}/libarchive-3.8.7.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/libarchive-3.8.7
    sed -i "/linux\/fs.h/d" libarchive/archive_read_disk_posix.c
