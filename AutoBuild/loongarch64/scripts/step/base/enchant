source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=enchant
export PACKAGE_VERSION=2.8.16
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/enchant/2.8.16/
rm -rf ${BUILD_DIRECTORY}/enchant-2.8.16
tar xvf ${DOWNLOADDIR}/enchant-2.8.16.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/enchant-2.8.16
	patch -Np1 -i ${SYSDIR}/files/base/enchant/2.8.16/patches/0001-enchant-2.8.10-fix-install-error.patch 
	 
	for config_i in $(find -name "config.sub")
	do
		cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
	done
	if [ ! -f configure ]; then
		autoreconf -ifv
	fi
	 ./configure ${COMMON_CONFIG} --enable-relocatable --enable-malloc0returnsnull
	CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" make -j${JOBS}
	run_step_package_check check
        make DESTDIR=${SYSROOT_DIR} install
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/enchant-2.8.16
