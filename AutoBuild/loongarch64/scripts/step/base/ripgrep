source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=ripgrep
export PACKAGE_VERSION=15.1.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/ripgrep/15.1.0/
rm -rf ${BUILD_DIRECTORY}/ripgrep-15.1.0
tar xvf ${DOWNLOADDIR}/ripgrep-15.1.0.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/ripgrep-15.1.0
    
    RUSTFLAGS="$RUSTFLAGS -C linker=${CROSS_TARGET}-gcc" \
    cargo build --release --target ${CROSS_TARGET}
    install -Dm755 target/${CROSS_TARGET}/release/rg ${SYSROOT_DIR}/usr/bin/
popd 
rm -rf ${BUILD_DIRECTORY}/ripgrep-15.1.0
