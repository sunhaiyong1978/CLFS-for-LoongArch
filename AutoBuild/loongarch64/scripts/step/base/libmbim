source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=libmbim
export PACKAGE_VERSION=1.34.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/libmbim/1.34.0/
rm -rf ${BUILD_DIRECTORY}/libmbim-1.34.0
tar xvf ${DOWNLOADDIR}/libmbim-1.34.0.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/libmbim-1.34.0
	
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG} -Dman=false \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}*.la
popd 
rm -rf ${BUILD_DIRECTORY}/libmbim-1.34.0
