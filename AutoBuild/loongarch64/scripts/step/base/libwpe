source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=libwpe
export PACKAGE_VERSION=1.16.3
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/libwpe/1.16.3/
