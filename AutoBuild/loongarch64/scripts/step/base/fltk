source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=fltk
export PACKAGE_VERSION=1.4.5
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/fltk/1.4.5/
rm -rf ${BUILD_DIRECTORY}/fltk-1.4.5
tar xvf ${DOWNLOADDIR}/fltk-1.4.5-source.tar.bz2 -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/fltk-1.4.5
    for config_i in $(find -name "config.sub")
    do
            cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
    done

    ./configure ${COMMON_CONFIG} --enable-shared --disable-test
    eval ${MAKE_AND_INSTALL}
    cp -v ${SYSROOT_DIR}/usr/bin/fltk-config ${CROSSTOOLS_DIR}/bin/
popd 
rm -rf ${BUILD_DIRECTORY}/fltk-1.4.5
