source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=ModemManager
export PACKAGE_VERSION=1.24.2
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/ModemManager/1.24.2/
rm -rf ${BUILD_DIRECTORY}/ModemManager-1.24.2
tar xvf ${DOWNLOADDIR}/ModemManager-1.24.2.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/ModemManager-1.24.2
	
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG} -Dudevdir=/usr/lib/udev -Dsystemdsystemunitdir=/usr/lib/systemd/system \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}*.la
popd 
rm -rf ${BUILD_DIRECTORY}/ModemManager-1.24.2
