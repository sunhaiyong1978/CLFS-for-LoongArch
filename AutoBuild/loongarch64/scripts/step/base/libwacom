source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=libwacom
export PACKAGE_VERSION=2.18.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/libwacom/2.18.0/
rm -rf ${BUILD_DIRECTORY}/libwacom-2.18.0
tar xvf ${DOWNLOADDIR}/libwacom-2.18.0.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/libwacom-2.18.0
	
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG}  -Dtests=disabled \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}*.la
popd 
rm -rf ${BUILD_DIRECTORY}/libwacom-2.18.0
