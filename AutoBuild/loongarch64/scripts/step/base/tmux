source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=tmux
export PACKAGE_VERSION=3.6a
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/tmux/3.6a/
rm -rf ${BUILD_DIRECTORY}/tmux-3.6a
tar xvf ${DOWNLOADDIR}/tmux-3.6a.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/tmux-3.6a
    for config_i in $(find -name "config.sub")
    do
            cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
    done

    ./configure ${COMMON_CONFIG} --with-TERM=screen
    eval ${MAKE_AND_INSTALL}
    install -m 644 example_tmux.conf ${SYSROOT_DIR}/etc/example_tmux.conf
popd 
rm -rf ${BUILD_DIRECTORY}/tmux-3.6a
