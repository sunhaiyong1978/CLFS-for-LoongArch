source env/base/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=base
export STEP_PACKAGENAME=gnome-keyring
export PACKAGE_VERSION=50.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/base/gnome-keyring/50.0/
rm -rf ${BUILD_DIRECTORY}/gnome-keyring-50.0
tar xvf ${DOWNLOADDIR}/gnome-keyring-50.0.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/gnome-keyring-50.0
	patch -Np1 -i ${SYSDIR}/files/base/gnome-keyring/50.0/patches/0001-gnome-keyring-48-fix-systemd-dir-for-cross-build.patch 
	 
	mkdir cross-build
	pushd cross-build
		 meson ${MESON_CONFIG} -Dpkcs11-config=/usr/share/p11-kit/modules -Dpkcs11-modules=/usr/lib${LIB_SUFF}/pkcs11 \
                      ..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		eval ${NINJA_AND_INSTALL}
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}*.la
popd 
rm -rf ${BUILD_DIRECTORY}/gnome-keyring-50.0
